# Release-Signierung (B8, ROADMAP.md): Kopie dieser Datei als
# keystore.properties anlegen (gitignored!) und ausfüllen.
#
# Keystore einmalig anlegen (dediziertes Passwort wählen und SICHER verwahren —
# ohne den Key sind keine Updates einer veröffentlichten App mehr möglich):
#
#   & "$env:JAVA_HOME\bin\keytool.exe" -genkeypair -v `
#     -keystore C:\Users\<user>\keystores\geoquiz-release.jks `
#     -alias geoquiz -keyalg RSA -keysize 2048 -validity 10000
#
# Der Keystore gehört AUSSERHALB des Repos (z. B. C:\Users\<user>\keystores\).

storeFile=C\:\\Users\\<user>\\keystores\\geoquiz-release.jks
storePassword=HIER_STORE_PASSWORT
keyAlias=geoquiz
keyPassword=HIER_KEY_PASSWORT
